    "method": "POST",
    "url": "https://api.easyship.com/2024-09/rates",
    "headers": {
      "Authorization": "Bearer prod_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "Content-Type": "application/json"
    },
